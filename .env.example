# ─── WHITE GLOVE WIRELESS · BACKEND ENV ──────────────────────────────────────
# Copy this file to .env and fill in your real keys
# NEVER commit .env to GitHub

# ── SERVER ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# Your frontend URL (for CORS) — change to your Vercel URL in production
FRONTEND_URL=http://localhost:3000

# ── SUPABASE (Database) ───────────────────────────────────────────────────────
# Get these from: supabase.com → your project → Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# ── BLAND.AI (AI Voice Calls) ─────────────────────────────────────────────────
# Get from: app.bland.ai → Settings → API Keys
BLAND_API_KEY=your-bland-api-key

# Your public backend URL so Bland.ai can send call results back to you
# Example: https://white-glove-backend.railway.app
WEBHOOK_BASE_URL=https://your-backend-url.railway.app

# ── GOOGLE PLACES (Business Search) ──────────────────────────────────────────
# Get from: console.cloud.google.com → Enable Places API → Credentials
GOOGLE_PLACES_API_KEY=your-google-places-key

# ── APOLLO.IO (Lead Enrichment) ───────────────────────────────────────────────
# Get from: app.apollo.io → Settings → Integrations → API Keys
APOLLO_API_KEY=your-apollo-api-key

# ── TWILIO (SMS Outreach) ─────────────────────────────────────────────────────
# Get from: console.twilio.com → Account Info
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+12065550000

# ── ANTHROPIC (AI Sales Intel) ────────────────────────────────────────────────
# Get from: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=your-anthropic-api-key
